{
  "name": "nextstep-dashboard-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "openapi:generate": "openapi-typescript ../nextstep-dashboard-backend/api/openapi.yaml -o src/api/schema.d.ts && node scripts/update-contract.mjs",
    "contract:verify": "node scripts/verify-contract.mjs"
  },
  "dependencies": {
    "@line/liff": "2.29.1",
    "@primeuix/themes": "2.0.3",
    "chart.js": "4.5.1",
    "primeicons": "7.0.0",
    "primevue": "4.5.4",
    "tailwindcss-primeui": "0.6.1",
    "vue": "3.5.39",
    "vue-router": "4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@primevue/auto-import-resolver": "4.5.5",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "26.1.0",
    "openapi-typescript": "7.8.0",
    "sass": "1.89.2",
    "tailwindcss": "4.3.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.63.0",
    "unplugin-vue-components": "32.1.0",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "vue-tsc": "2.2.10"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
